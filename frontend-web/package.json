    "decimal.js": "^10.4.3",
    "jose": "^5.2.4",
    "js-cookie": "^3.0.5",
    "sonner": "^1.4.3",
    "recharts": "^2.12.3",
    "lucide-react": "^0.359.0",
    "class-variance-authority": "^0.7.0",
